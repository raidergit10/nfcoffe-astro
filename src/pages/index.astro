---
import MainLayout from '../layouts/MainLayout.astro';

// Di sini kamu bisa melakukan fetch data menu dari API/file lokal jika ada ke depannya
---

<MainLayout 
	title="NF Coffee | Sensasi Kopi Lokal Kualitas Premium"
	description="Selamat datang di NF Coffee. Temukan racikan menu espresso dan manual brew terbaik dari barista berpengalaman."
>
	<!-- SECTION HERO -->
	<section class="py-20 bg-gradient-to-b from-[#f5eee6] to-[#faf8f5]">
		<div class="max-w-4xl mx-auto text-center px-4">
			<span class="text-xs font-bold uppercase tracking-widest text-[#6f4e37] bg-[#f5eee6] px-3 py-1 rounded-full">
				Premium Coffee Experience
			</span>
			<h1 class="text-4xl md:text-6xl font-extrabold mt-4 mb-6 text-[#332211] leading-tight">
				Awali Hari Anda Bersama <br/>
				<span class="text-[#6f4e37]">Secangkir Kopi Murni</span>
			</h1>
			<p class="text-base text-[#665544] max-w-xl mx-auto mb-8">
				Dibuat dengan dedikasi tinggi menggunakan biji kopi pilihan berkualitas yang dipanggang dengan sempurna untuk menjaga aroma naturalnya.
			</p>
			<div class="flex justify-center gap-4">
				<a href="#menu" class="bg-[#6f4e37] text-white px-6 py-3 rounded-xl font-medium shadow-md hover:bg-[#5a3e2b] transition">
					Lihat Menu Kami
				</a>
			</div>
		</div>
	</section>

	<!-- SECTION MENU -->
	<section id="menu" class="py-16 max-w-6xl mx-auto px-4">
		<h2 class="text-2xl font-bold text-center text-[#332211] mb-2">Menu Favorit Kami</h2>
		<p class="text-sm text-center text-[#665544] mb-12">Pilihan racikan racikan terbaik paling diminati pengunjung</p>
		
		<div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6">
			<!-- Kartu Kopi 1 -->
			<div class="bg-white p-4 rounded-2xl border border-[#eaddd0] shadow-sm">
				<div class="w-full h-48 bg-[#f5eee6] rounded-xl mb-4 flex items-center justify-center text-[#a69584]">
					[ Gambar Kopi ]
				</div>
				<h3 class="font-bold text-[#332211]">Espresso Blend</h3>
				<p class="text-xs text-[#665544] mt-1 mb-4">Ekstraksi kopi murni yang pekat dengan crema tebal.</p>
				<div class="flex justify-between items-center">
					<span class="font-bold text-[#6f4e37] text-sm">Rp 20.000</span>
				</div>
			</div>

			<!-- Kartu Kopi 2 -->
			<div class="bg-white p-4 rounded-2xl border border-[#eaddd0] shadow-sm">
				<div class="w-full h-48 bg-[#f5eee6] rounded-xl mb-4 flex items-center justify-center text-[#a69584]">
					[ Gambar Kopi ]
				</div>
				<h3 class="font-bold text-[#332211]">Cafe Latte</h3>
				<p class="text-xs text-[#665544] mt-1 mb-4">Paduan lembut susu segar hangat dan shot espresso premium.</p>
				<div class="flex justify-between items-center">
					<span class="font-bold text-[#6f4e37] text-sm">Rp 25.000</span>
				</div>
			</div>
		</div>
	</section>
</MainLayout>