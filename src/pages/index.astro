---
// src/pages/index.astro
const resto = {
  nama: "NF Coffee & Resto",
  tagline: "Tempat ngopi & nongkrong paling representatif di Majene",
  rating: 4.2,
  jumlahUlasan: 72,
  harga: "Rp 25.000 – 50.000 / orang",
  kategori: "Kedai Kopi & Resto",
  alamat:
    "FX4P+H94, Lembang Dhua, Baurung, Kec. Banggae Tim., Kabupaten Majene, Sulawesi Barat 91412",
  telepon: "0851-7422-3221",
  teleponLink: "tel:085174223221",
  instagram: "https://instagram.com/nfcoffeeandresto",
  menu: "https://app.menulike.com/id-nf-coffee-and-resto",
  maps: "https://maps.google.com/?q=NF+Coffee+and+Resto+Majene",
};

const layanan = [
  { icon: "🍽️", judul: "Makan di Tempat", desc: "Suasana nyaman buat nongkrong & kerja tugas." },
  { icon: "🥡", judul: "Bawa Pulang", desc: "Pesan favoritmu untuk dibawa pulang." },
  { icon: "🛵", judul: "Pesan Antar", desc: "Nikmati kopi tanpa keluar rumah." },
];

const fasilitas = [
  { icon: "🅿️", teks: "Parkiran luas di depan cafe" },
  { icon: "🕌", teks: "Mushallah" },
  { icon: "🚻", teks: "Toilet pria & wanita bersih" },
  { icon: "🌇", teks: "Rooftop untuk sore & malam" },
  { icon: "👥", teks: "Ruangan untuk rapat & pertemuan" },
  { icon: "📸", teks: "Dekorasi & lampu Instagramable" },
];

const menuUnggulan = [
  { nama: "Aneka Kopi", desc: "Menu kopi rekomended semua, favorit pelanggan." },
  { nama: "Snack & Camilan", desc: "Teman pas buat nongkrong dan ngobrol santai." },
  { nama: "Minuman Non-Kopi", desc: "Pilihan segar untuk yang bukan pencinta kopi." },
];

const ulasan = [
  {
    nama: "Taufiqurrahman",
    label: "Local Guide · 736 ulasan",
    waktu: "5 bulan lalu",
    isi: "Menu kopinya rekomended semua. Suasananya bagus buat nongkrong atau kerja tugas. Ada beberapa ruangan juga untuk rapat atau pertemuan kecil. Sore atau malam enaknya di rooftop sih nongkrong.",
  },
  {
    nama: "Nurasia Halede",
    label: "Local Guide · 52 ulasan",
    waktu: "3 tahun lalu",
    isi: "Tempatnya sangat cocok dijadikan tempat nongkrong di sore menjelang malam. Sangat disarankan makan di lantai dua untuk menikmati sinar matahari senja. Penataan dekorasi dan lampu sangat Instagramable.",
  },
  {
    nama: "Sriwiyata Ismail Zainuddin",
    label: "6 ulasan",
    waktu: "2 tahun lalu",
    isi: "5 stars for this place! Tempat yang paling representatif untuk bekerja dan meeting di area Majene.",
  },
];

const tahun = new Date().getFullYear();
---

<!doctype html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content={`${resto.nama} - ${resto.tagline}. ${resto.alamat}`}
    />
    <title>{resto.nama} — Kedai Kopi & Resto di Majene</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=Poppins:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <!-- NAVBAR -->
    <header class="nav">
      <a href="#beranda" class="brand">NF<span>Coffee</span></a>
      <nav>
        <a href="#tentang">Tentang</a>
        <a href="#menu">Menu</a>
        <a href="#fasilitas">Fasilitas</a>
        <a href="#ulasan">Ulasan</a>
        <a href="#lokasi">Lokasi</a>
      </nav>
      <a href={resto.menu} target="_blank" rel="noopener" class="btn btn-nav"
        >Lihat Menu</a
      >
    </header>

    <!-- HERO -->
    <section id="beranda" class="hero">
      <div class="hero-inner">
        <span class="pill">☕ {resto.kategori}</span>
        <h1>{resto.nama}</h1>
        <p class="tagline">{resto.tagline}</p>
        <div class="rating">
          <span class="stars">★★★★☆</span>
          <strong>{resto.rating}</strong>
          <span class="muted">({resto.jumlahUlasan} ulasan)</span>
          <span class="dot">·</span>
          <span class="muted">{resto.harga}</span>
        </div>
        <div class="hero-cta">
          <a href={resto.maps} target="_blank" rel="noopener" class="btn"
            >📍 Rute ke Lokasi</a
          >
          <a href={resto.teleponLink} class="btn btn-ghost"
            >📞 {resto.telepon}</a
          >
        </div>
      </div>
    </section>

    <!-- LAYANAN -->
    <section class="layanan">
      {
        layanan.map((l) => (
          <div class="layanan-card">
            <span class="layanan-icon">{l.icon}</span>
            <h3>{l.judul}</h3>
            <p>{l.desc}</p>
          </div>
        ))
      }
    </section>

    <!-- TENTANG -->
    <section id="tentang" class="tentang">
      <div class="tentang-text">
        <h2>Tentang Kami</h2>
        <p>
          {resto.nama} adalah kedai kopi dan resto yang jadi tempat paling
          representatif untuk nongkrong, bekerja, dan meeting di area Majene.
          Dengan suasana yang nyaman, rooftop untuk menikmati senja, serta
          dekorasi yang Instagramable, kami hadir untuk menemani hari-harimu.
        </p>
        <p>
          Cocok untuk kerja tugas, rapat kecil, atau sekadar bersantai sore
          menjelang malam ditemani secangkir kopi favorit.
        </p>
        <a href={resto.instagram} target="_blank" rel="noopener" class="btn"
          >📷 Ikuti Instagram Kami</a
        >
      </div>
      <div class="tentang-highlight">
        <div class="hl-box">
          <strong>{resto.rating}/5</strong>
          <span>Rating Google</span>
        </div>
        <div class="hl-box">
          <strong>{resto.jumlahUlasan}+</strong>
          <span>Ulasan Pengunjung</span>
        </div>
        <div class="hl-box">
          <strong>24/7</strong>
          <span>Suasana Nyaman</span>
        </div>
      </div>
    </section>

    <!-- MENU -->
    <section id="menu" class="menu">
      <h2>Menu Unggulan</h2>
      <p class="section-sub">Kopi rekomended, snack, dan minuman segar.</p>
      <div class="menu-grid">
        {
          menuUnggulan.map((m) => (
            <div class="menu-card">
              <h3>{m.nama}</h3>
              <p>{m.desc}</p>
            </div>
          ))
        }
      </div>
      <a href={resto.menu} target="_blank" rel="noopener" class="btn btn-center"
        >Lihat Menu Lengkap →</a
      >
    </section>

    <!-- FASILITAS -->
    <section id="fasilitas" class="fasilitas">
      <h2>Fasilitas</h2>
      <div class="fasilitas-grid">
        {
          fasilitas.map((f) => (
            <div class="fasilitas-item">
              <span>{f.icon}</span>
              <p>{f.teks}</p>
            </div>
          ))
        }
      </div>
    </section>

    <!-- ULASAN -->
    <section id="ulasan" class="ulasan">
      <h2>Kata Mereka</h2>
      <div class="ulasan-grid">
        {
          ulasan.map((u) => (
            <blockquote class="ulasan-card">
              <div class="stars">★★★★★</div>
              <p>“{u.isi}”</p>
              <footer>
                <strong>{u.nama}</strong>
                <span>{u.label} · {u.waktu}</span>
              </footer>
            </blockquote>
          ))
        }
      </div>
    </section>

    <!-- LOKASI / KONTAK -->
    <section id="lokasi" class="lokasi">
      <div class="lokasi-info">
        <h2>Kunjungi Kami</h2>
        <p class="alamat">📍 {resto.alamat}</p>
        <p>📞 <a href={resto.teleponLink}>{resto.telepon}</a></p>
        <p>
          📷 <a href={resto.instagram} target="_blank" rel="noopener"
            >@nfcoffeeandresto</a
          >
        </p>
        <div class="lokasi-cta">
          <a href={resto.maps} target="_blank" rel="noopener" class="btn"
            >Buka di Google Maps</a
          >
          <a href={resto.menu} target="_blank" rel="noopener" class="btn btn-ghost"
            >Lihat Menu</a
          >
        </div>
      </div>
      <div class="lokasi-map">
        <iframe
          title="Peta NF Coffee & Resto"
          src="https://www.google.com/maps?q=NF%20Coffee%20and%20Resto%20Majene&output=embed"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"></iframe>
      </div>
    </section>

    <!-- FOOTER -->
    <footer class="footer">
      <strong>{resto.nama}</strong>
      <p>{resto.kategori} · Majene, Sulawesi Barat</p>
      <p class="copy">© {tahun} {resto.nama}. Dibuat dengan ☕ & Astro.</p>
    </footer>

    <style>
      :root {
        --coffee: #4b2e21;
        --coffee-dark: #35201780;
        --cream: #f6efe7;
        --accent: #c98a4b;
        --text: #2b211c;
        --muted: #7a6b60;
      }
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }
      html {
        scroll-behavior: smooth;
      }
      body {
        font-family: "Poppins", system-ui, sans-serif;
        color: var(--text);
        background: var(--cream);
        line-height: 1.6;
      }
      h1,
      h2,
      h3 {
        font-family: "Playfair Display", serif;
      }
      section {
        padding: 5rem 1.5rem;
      }
      h2 {
        font-size: clamp(1.8rem, 4vw, 2.6rem);
        text-align: center;
        color: var(--coffee);
        margin-bottom: 0.5rem;
      }
      .section-sub {
        text-align: center;
        color: var(--muted);
        margin-bottom: 2.5rem;
      }
      .btn {
        display: inline-block;
        background: var(--coffee);
        color: #fff;
        padding: 0.8rem 1.6rem;
        border-radius: 999px;
        text-decoration: none;
        font-weight: 500;
        transition: transform 0.2s, background 0.2s;
      }
      .btn:hover {
        background: var(--accent);
        transform: translateY(-2px);
      }
      .btn-ghost {
        background: transparent;
        border: 1.5px solid var(--coffee);
        color: var(--coffee);
      }
      .btn-ghost:hover {
        background: var(--coffee);
        color: #fff;
      }
      .btn-center {
        display: block;
        width: fit-content;
        margin: 2.5rem auto 0;
      }

      /* NAV */
      .nav {
        position: sticky;
        top: 0;
        z-index: 50;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        padding: 1rem 1.5rem;
        background: rgba(246, 239, 231, 0.92);
        backdrop-filter: blur(10px);
        border-bottom: 1px solid #e6dccf;
      }
      .brand {
        font-family: "Playfair Display", serif;
        font-weight: 700;
        font-size: 1.4rem;
        color: var(--coffee);
        text-decoration: none;
      }
      .brand span {
        color: var(--accent);
      }
      .nav nav {
        display: flex;
        gap: 1.4rem;
      }
      .nav nav a {
        color: var(--text);
        text-decoration: none;
        font-size: 0.95rem;
      }
      .nav nav a:hover {
        color: var(--accent);
      }
      .btn-nav {
        padding: 0.55rem 1.1rem;
        font-size: 0.9rem;
      }

      /* HERO */
      .hero {
        min-height: 82vh;
        display: flex;
        align-items: center;
        justify-content: center;
        text-align: center;
        color: #fff;
        background:
          linear-gradient(var(--coffee-dark), rgba(30, 18, 12, 0.75)),
          url("https://images.unsplash.com/photo-1554118811-1e0d58224f24?auto=format&fit=crop&w=1600&q=80")
            center/cover;
      }
      .hero-inner {
        max-width: 720px;
      }
      .pill {
        display: inline-block;
        background: rgba(255, 255, 255, 0.15);
        border: 1px solid rgba(255, 255, 255, 0.3);
        padding: 0.35rem 1rem;
        border-radius: 999px;
        font-size: 0.85rem;
        margin-bottom: 1.2rem;
      }
      .hero h1 {
        font-size: clamp(2.6rem, 7vw, 4.5rem);
        line-height: 1.1;
      }
      .tagline {
        font-size: 1.15rem;
        margin: 1rem 0 1.4rem;
        opacity: 0.92;
      }
      .rating {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        flex-wrap: wrap;
        margin-bottom: 2rem;
        font-size: 1rem;
      }
      .stars {
        color: #ffcf5c;
        letter-spacing: 2px;
      }
      .muted {
        opacity: 0.85;
      }
      .dot {
        opacity: 0.6;
      }
      .hero-cta {
        display: flex;
        gap: 1rem;
        justify-content: center;
        flex-wrap: wrap;
      }
      .hero-cta .btn-ghost {
        border-color: #fff;
        color: #fff;
      }

      /* LAYANAN */
      .layanan {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
        gap: 1.5rem;
        max-width: 1100px;
        margin: -3rem auto 0;
        padding: 0 1.5rem;
        position: relative;
        z-index: 10;
      }
      .layanan-card {
        background: #fff;
        border-radius: 18px;
        padding: 2rem 1.5rem;
        text-align: center;
        box-shadow: 0 12px 30px rgba(75, 46, 33, 0.1);
      }
      .layanan-icon {
        font-size: 2.4rem;
      }
      .layanan-card h3 {
        color: var(--coffee);
        margin: 0.6rem 0 0.4rem;
      }
      .layanan-card p {
        color: var(--muted);
        font-size: 0.95rem;
      }

      /* TENTANG */
      .tentang {
        display: grid;
        grid-template-columns: 1.4fr 1fr;
        gap: 3rem;
        align-items: center;
        max-width: 1100px;
        margin: 0 auto;
      }
      .tentang h2 {
        text-align: left;
      }
      .tentang p {
        color: var(--muted);
        margin: 1rem 0;
      }
      .tentang-highlight {
        display: grid;
        gap: 1rem;
      }
      .hl-box {
        background: var(--coffee);
        color: #fff;
        border-radius: 16px;
        padding: 1.4rem;
        text-align: center;
      }
      .hl-box strong {
        display: block;
        font-size: 1.8rem;
        font-family: "Playfair Display", serif;
      }
      .hl-box span {
        opacity: 0.85;
        font-size: 0.9rem;
      }

      /* MENU */
      .menu {
        background: #fff;
      }
      .menu-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 1.5rem;
        max-width: 1000px;
        margin: 0 auto;
      }
      .menu-card {
        border: 1px solid #eaddcf;
        border-radius: 16px;
        padding: 1.8rem;
        transition: transform 0.2s, box-shadow 0.2s;
      }
      .menu-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 14px 30px rgba(75, 46, 33, 0.12);
      }
      .menu-card h3 {
        color: var(--coffee);
        margin-bottom: 0.4rem;
      }
      .menu-card p {
        color: var(--muted);
        font-size: 0.95rem;
      }

      /* FASILITAS */
      .fasilitas-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
        gap: 1.2rem;
        max-width: 1000px;
        margin: 0 auto;
      }
      .fasilitas-item {
        display: flex;
        align-items: center;
        gap: 0.9rem;
        background: #fff;
        border-radius: 14px;
        padding: 1.1rem 1.3rem;
        box-shadow: 0 6px 16px rgba(75, 46, 33, 0.06);
      }
      .fasilitas-item span {
        font-size: 1.6rem;
      }
      .fasilitas-item p {
        font-weight: 500;
      }

      /* ULASAN */
      .ulasan {
        background: #fff;
      }
      .ulasan-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 1.5rem;
        max-width: 1100px;
        margin: 0 auto;
      }
      .ulasan-card {
        background: var(--cream);
        border-radius: 18px;
        padding: 2rem;
        border: 1px solid #eee0d1;
      }
      .ulasan-card .stars {
        color: #f0a929;
        margin-bottom: 0.8rem;
      }
      .ulasan-card p {
        font-style: italic;
        color: var(--text);
        margin-bottom: 1.2rem;
      }
      .ulasan-card footer strong {
        display: block;
        color: var(--coffee);
      }
      .ulasan-card footer span {
        font-size: 0.85rem;
        color: var(--muted);
      }

      /* LOKASI */
      .lokasi {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 2.5rem;
        align-items: center;
        max-width: 1100px;
        margin: 0 auto;
      }
      .lokasi h2 {
        text-align: left;
      }
      .lokasi-info p {
        margin: 0.7rem 0;
        color: var(--text);
      }
      .lokasi-info a {
        color: var(--accent);
        text-decoration: none;
      }
      .alamat {
        color: var(--muted) !important;
      }
      .lokasi-cta {
        display: flex;
        gap: 1rem;
        flex-wrap: wrap;
        margin-top: 1.5rem;
      }
      .lokasi-map iframe {
        width: 100%;
        height: 340px;
        border: 0;
        border-radius: 18px;
        box-shadow: 0 12px 30px rgba(75, 46, 33, 0.15);
      }

      /* FOOTER */
      .footer {
        background: var(--coffee);
        color: #fff;
        text-align: center;
        padding: 3rem 1.5rem;
      }
      .footer strong {
        font-family: "Playfair Display", serif;
        font-size: 1.4rem;
      }
      .footer p {
        opacity: 0.85;
        margin-top: 0.3rem;
      }
      .footer .copy {
        margin-top: 1rem;
        font-size: 0.85rem;
        opacity: 0.6;
      }

	  
      /* RESPONSIVE */
      @media (max-width: 820px) {
        .tentang,
        .lokasi {
          grid-template-columns: 1fr;
        }
        .nav nav {
          display: none;
        }
      }
    </style>
  </body>
</html>