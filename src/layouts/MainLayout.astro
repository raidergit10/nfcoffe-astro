---
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

interface Props {
	title?: string;
	description?: string;
}

const { 
	title = "NF Coffee | Cyber Roastery & Premium Experience", 
	description = "Nikmati pilihan biji kopi Arabika dan Robusta terbaik dengan konsep modern futuristik di NF Coffee." 
} = Astro.props;
---

<!doctype html>
<html lang="id" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		
		<!-- SEO Basics -->
		<title>{title}</title>
		<meta name="description" content={description} />
		<meta name="robots" content="index, follow" />
		
		<!-- Google Fonts Integration -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
	</head>
	<body class="bg-[#070708] text-[#f3f4f6] min-h-screen flex flex-col font-['Plus_Jakarta_Sans',sans-serif] selection:bg-[#a855f7] selection:text-white antialiased">
		
		<!-- Navbar -->
		<Navbar />

		<!-- Main Content Slot -->
		<main class="flex-grow">
			<slot />
		</main>

		<!-- Footer -->
		<Footer />

	</body>
</html>